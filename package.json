{
  "name": "booking-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "copy:antd-css": "cp node_modules/antd/dist/reset.css public/antd-reset.css",
    "dev": "npm run copy:antd-css && astro dev",
    "build": "npm run copy:antd-css && IS_DEPLOYING=true astro build",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler pages deploy ./dist",
    "db:migrate:local": "npx wrangler d1 execute mde-booking-db --local --file=./migrations/001-init.sql",
    "db:migrate:remote": "npx wrangler d1 execute mde-booking-db --remote --file=./migrations/001-init.sql"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "@astrojs/cloudflare": "^12.0.0",
    "@astrojs/react": "^5.0.2",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "antd": "^6.3.5",
    "astro": "^5.0.0",
    "aws4fetch": "^1.0.20",
    "dayjs": "^1.11.20",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "wrangler": "^3.0.0"
  }
}
