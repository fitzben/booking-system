---
import BaseLayout from '../layouts/BaseLayout.astro';
import LandingNav from '../components/landing/LandingNav';
import BookingSection from '../components/landing/BookingSection';
---

<BaseLayout
  title="Ajukan Peminjaman – MD Entertainment"
  noIndex={true}
>
  <style is:global>
    body { min-height: 100vh; display: flex; flex-direction: column; }
    main { flex: 1; padding-top: 68px; } /* Offset for sticky nav */
    
    /* Make sure the booking section fits nicely on a full page */
    @media (max-width: 768px) {
      .booking-section-inner {
        padding: 24px;
        border-radius: 0;
      }
      .booking-section {
        padding-top: 40px !important;
      }
    }
  </style>

  <LandingNav client:load />

  <main>
    <div style="max-width: 1000px; margin: 0 auto; padding: 0 20px;">
      <div class="bfs-skeleton-wrap">
        <BookingSection client:load />
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer style="background:#030b15;border-top:1px solid rgba(255,255,255,0.06);padding:48px 24px;text-align:center;">
    <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:8px;">
      <img src="/MDE_logo.png" alt="MD Entertainment" style="height:24px;width:auto;" />
    </div>
    <p style="color:rgba(148,163,184,0.5);font-size:12px;margin:16px 0 0;">
      &copy; {new Date().getFullYear()} MD Entertainment &middot; mdentertainment.com
    </p>
  </footer>
</BaseLayout>
